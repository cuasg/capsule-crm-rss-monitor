{
  "manifest_version": 3,
  "name": "Capsule CRM Activity Monitor",
  "description": "Tracks Capsule CRM activity with refresh, notifications, a side panel, and optional AI summaries.",
  "version": "2.0",
  "action": {
    "default_title": "Capsule Activity Monitor",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "alarms",
    "notifications",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.capsulecrm.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "popup.html",
    "open_panel_on_action_click": false
  },
  "options_page": "options.html"
}
